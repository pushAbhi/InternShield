{
    "name" : "ScamShield",
    "description" : "Base Level Extension",
    "version" : "1.0",
    "manifest_version" : 3,
    "action" : {
        "default_popup" : "popup/popup.html",
        "default_icon" : "images/icon.png"
    },
    "permissions" : [
        "scripting",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ]

}